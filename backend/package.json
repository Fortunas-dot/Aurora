{
  "name": "aurora-backend",
  "version": "1.0.0",
  "description": "Aurora A.I. Mental Health Support Companion Backend API",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc && npm run check-security",
    "watch": "tsc --watch",
    "check-security": "node scripts/check-security.js",
    "seed": "ts-node src/scripts/seed.ts",
    "create-apple-account": "ts-node src/scripts/create-apple-review-account.ts",
    "create-showcase-account": "ts-node src/scripts/create-showcase-account.ts",
    "remove-group-avatars": "ts-node src/scripts/remove-group-avatars.ts",
    "remove-showcase-posts": "ts-node src/scripts/remove-showcase-posts.ts",
    "create-anonymous-duck": "ts-node src/scripts/createAnonymousDuck.ts",
    "create-whoislisa": "ts-node src/scripts/createWhoIsLisa.ts",
    "create-silentsoul": "ts-node src/scripts/createSilentSoul.ts",
    "create-brokenwings": "ts-node src/scripts/createBrokenWings.ts",
    "create-hiddenvoice": "ts-node src/scripts/createHiddenVoice.ts",
    "remove-duplicates": "ts-node src/scripts/removeDuplicateEntries.ts",
    "normalize-urls": "ts-node src/scripts/normalizePostUrls.ts",
    "loadtest:chat": "autocannon -c 20 -d 60 -p 10 https://YOUR_BACKEND_URL/api/ai/chat"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "expo-server-sdk": "^5.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "express-ws": "^5.0.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "twilio": "^5.12.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/twilio": "^3.19.2",
    "@types/ws": "^8.5.10",
    "autocannon": "^8.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
